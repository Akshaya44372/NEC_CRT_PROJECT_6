    {"name": "parent_id", "type": "INT", "primary_key": true},
    {"name": "parent_name", "type": "VARCHAR(100)"},
    {"name": "phone", "type": "VARCHAR(20)"},
    {"name": "email", "type": "VARCHAR(100)"}
