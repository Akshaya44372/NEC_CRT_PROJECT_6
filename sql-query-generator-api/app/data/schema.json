  "description": "Company office locations",
  "columns": [
    {"name": "office_id", "type": "INT", "primary_key": true},
    {"name": "office_name", "type": "VARCHAR(100)"},
    {"name": "building", "type": "VARCHAR(100)"},
    {"name": "floor", "type": "VARCHAR(20)"},
    {"name": "city", "type": "VARCHAR(80)"},
    {"name": "state", "type": "VARCHAR(80)"},
    {"name": "country", "type": "VARCHAR(80)"}
  ]
},

{
  "name": "projects",
  "description": "Company projects",
  "columns": [
    {"name": "project_id", "type": "INT", "primary_key": true},
    {"name": "project_name", "type": "VARCHAR(150)"},
    {"name": "department_id", "type": "INT"},
    {"name": "budget", "type": "DECIMAL(12,2)"},
    {"name": "start_date", "type": "DATE"},
    {"name": "end_date", "type": "DATE"},
    {"name": "status", "type": "VARCHAR(30)"}
  ]
},

{
