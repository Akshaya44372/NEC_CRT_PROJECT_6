{
"database": "universal_db",
"dialect": "mysql",

"tables": [
{
"name": "employees",
"description": "Company employees",
"columns": [
{"name": "employee_id", "type": "INT", "primary_key": true},
{"name": "first_name", "type": "VARCHAR(50)"},
{"name": "last_name", "type": "VARCHAR(50)"},
{"name": "age", "type": "INT"},
{"name": "gender", "type": "VARCHAR(10)"},
{"name": "email", "type": "VARCHAR(100)"},
{"name": "phone", "type": "VARCHAR(20)"},
{"name": "hire_date", "type": "DATE"},
{"name": "salary", "type": "DECIMAL(10,2)"},
{"name": "department_id", "type": "INT"},
{"name": "office_id", "type": "INT"},
{"name": "manager_id", "type": "INT"},
{"name": "job_title", "type": "VARCHAR(100)"},
{"name": "status", "type": "VARCHAR(20)"}
]
},
{
  "name": "departments",
  "description": "Company departments",
  "columns": [
    {"name": "department_id", "type": "INT", "primary_key": true},
    {"name": "department_name", "type": "VARCHAR(100)"},
    {"name": "location", "type": "VARCHAR(100)"},
    {"name": "budget", "type": "DECIMAL(12,2)"}
  ]
},

{
