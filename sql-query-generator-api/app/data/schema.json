    {"name": "course_id", "type": "INT", "primary_key": true},
    {"name": "course_name", "type": "VARCHAR(100)"},
    {"name": "teacher_id", "type": "INT"},
    {"name": "school_id", "type": "INT"}
  ]
},

{
  "name": "enrollments",
